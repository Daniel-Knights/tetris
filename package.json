{
  "name": "tetris",
  "private": true,
  "version": "0.4.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/Daniel-Knights/tetris"
  },
  "type": "module",
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "dev": "tauri dev",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "pnpm run checks && tauri build",
    "build:web": "pnpm run checks && vite build --config vite.config.web.ts",
    "preview:web": "pnpm run build:web && vite preview --config vite.config.web.ts",
    "icon": "tauri icon ./artwork/icon.png",
    "info": "tauri info",
    "lint": "eslint",
    "checks": "pnpm run lint && tsc --noEmit",
    "format": "prettier --write ./src",
    "release:patch": "tsx ./scripts/release.ts patch",
    "release:minor": "tsx ./scripts/release.ts minor",
    "release:major": "tsx ./scripts/release.ts major"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tauri-apps/cli": "2.11.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "changenog": "^2.0.6",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.4.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.4.0"
    }
  }
}
